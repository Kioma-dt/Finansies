<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:entity="clr-namespace:BuisnessLogic.UseCases.TransactionsUseCasses.Commands;assembly=BuisnessLogic"
    x:TypeArguments="entity:UpdateTransactionCommand"
    xmlns:viewmodel="clr-namespace:UI.PopUps.ViewModels"
    x:Class="UI.Popups.TransactionUpdatePopUp"
    x:DataType="viewmodel:TransactionUpdatePopUpModel">

    <Grid RowDefinitions="*, Auto"
          ColumnDefinitions="*, *">

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Padding="20"
                BackgroundColor="White"
                WidthRequest="340"
                Stroke="LightGray"
                StrokeThickness="1">

            <ScrollView>
                <VerticalStackLayout Spacing="12">

                    <Label Text="Update Transaction"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="Black"/>


                    <Entry x:Name="DescriptionEntry"
                           Placeholder="Description"
                           TextColor="Black"
                           PlaceholderColor="Gray"
                           Text="{Binding Description}"/>

                    <DatePicker x:Name="TransactionDatePicker"
                        TextColor="Black"
                        Format="dd.MM.yyyy"/>

                    <Picker x:Name="CategoryPicker"
                            Title="Select category"
                            TextColor="Black"
                            TitleColor="Gray"
                            ItemsSource="{Binding Categories}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedCategory}"/>

                    <Picker x:Name="FamilyMemberPicker"
                            Title="Select family member"
                            TextColor="Black"
                            TitleColor="Gray"
                            ItemsSource="{Binding FamilyMembers}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedFamilyMember}"/>

                </VerticalStackLayout>
            </ScrollView>

        </Border>

        <Button Grid.Row="1"
                Grid.Column="0"
            Text="Cancel"
            BackgroundColor="#9E9E9E"
            TextColor="White"
            CornerRadius="8"
            Command="{Binding CancelCommand}"/>

        <Button Grid.Row="1"
                Grid.Column="1"
            Text="Update"
            BackgroundColor="#4CAF50"
            TextColor="White"
            CornerRadius="8"
            Command="{Binding CreateCommand}"/>
    </Grid>
</toolkit:Popup>