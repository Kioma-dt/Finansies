<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:dto="clr-namespace:UI.PopUps.ViewModels"
    xmlns:entity="clr-namespace:BuisnessLogic.UseCases.BudgetUseCasses.Commands;assembly=BuisnessLogic"
    x:TypeArguments="entity:CreateBudgetCommand"
    xmlns:viewmodel="clr-namespace:UI.PopUps.ViewModels"
    x:Class="UI.Popups.BudgetCreatePopUp"
    x:DataType="viewmodel:BudgetCreatePopUpModel"
    
    BackgroundColor="#99000000"
    >

    <Grid RowDefinitions="*, Auto"
      ColumnDefinitions="*, *"
      RowSpacing="20"
      ColumnSpacing="10">

        <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            WidthRequest="320"
            StrokeThickness="1"
            Style="{StaticResource PrimaryPopupBorderStyle}">

            <ScrollView
            VerticalScrollBarVisibility="Never"
            HorizontalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Create Budget"
                       Style="{StaticResource PopupTitleLabelStyle}"/>

                    <VerticalStackLayout Spacing="5">

                        <Label 
                             Text="Enter Name"
                            Style="{StaticResource SectionLabelStyle}"/>

                        <Entry x:Name="NameEntry"
                            Placeholder="Budget Name"
                            Text="{Binding Name}"/>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">

                        <Label 
                             Text="Enter Limit"
                            Style="{StaticResource SectionLabelStyle}"/>

                        <Entry x:Name="LimitEntry"
                            Placeholder="Budget Limit"
                            Text="{Binding Limit}"/>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label 
                             Text="Select Start Date"
                            Style="{StaticResource SectionLabelStyle}"/>

                        <DatePicker x:Name="StartDatePicker"
                            Date="{Binding StartDate}"/>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label 
                             Text="Select End Date"
                            Style="{StaticResource SectionLabelStyle}"/>

                        <DatePicker x:Name="EndDatePicker"
                            Date="{Binding EndDate}"/>

                    </VerticalStackLayout>

                    <Picker x:Name="TypePicker"
                        Title="Select Transaction Type"
                        ItemsSource="{Binding TransactionTypes}"
                        SelectedItem="{Binding SelectedTrasactionType}"/>

                    <VerticalStackLayout Spacing="5">
                        <Label 
                             Text="Add Filters"
                            Style="{StaticResource SectionLabelStyle}"/>

                        <Grid ColumnDefinitions="*, *"
                              RowDefinitions="*, Auto"
                              ColumnSpacing="10"
                              RowSpacing="10">
                            <Picker Grid.Column="0"
                                Grid.Row="0"
                                x:Name="FilterTypePicker"
                                ItemsSource="{Binding FilterTypes}"
                                SelectedItem="{Binding SelectedFilterType}">

                                <Picker.Behaviors>
                                    <toolkit:EventToCommandBehavior
                                        EventName="SelectedIndexChanged"
                                        Command="{Binding ChangeSelectedFilterCommand}"
                                        BindingContext="{Binding Source={x:Reference FilterTypePicker}, Path=BindingContext}" />        
                                </Picker.Behaviors>
                            </Picker>

                            <Picker Grid.Column="1"
                                    Grid.Row="0"
                                ItemsSource="{Binding Accounts}"
                                SelectedItem="{Binding SelectedAccount}"
                                ItemDisplayBinding="{Binding Name}"
                                IsVisible="{Binding IsAccountFilter}"/>

                            <Picker Grid.Column="1"
                                    Grid.Row="0"
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding SelectedCategory}"
                                ItemDisplayBinding="{Binding Name}"
                                IsVisible="{Binding IsCategoryFilter}"/>

                            <Picker Grid.Column="1"
                                    Grid.Row="0"
                                ItemsSource="{Binding FamilyMembers}"
                                SelectedItem="{Binding SelectedFamilyMember}"
                                ItemDisplayBinding="{Binding Name}"
                                IsVisible="{Binding IsFamilyMemberFilter}"/>

                            <Button Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="30, 0"
                                Text="Add"
                                Command="{Binding AddFilterCommand}"
                                Style="{StaticResource PurpleButtonStyle}"/>
                        </Grid>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">

                        <Label HorizontalOptions="Center"
                             Text="Selected Filters"
                            Style="{StaticResource SectionLabelStyle}"/>

                        <Grid ColumnDefinitions="*, *">
                            <Label Grid.Column="0"
                                 Text="Filters Type"
                                Style="{StaticResource SectionLabelStyle}"/>
                            <Label Grid.Column="1"
                                 Text="Filters Value"
                                Style="{StaticResource SectionLabelStyle}"/>
                            
                        </Grid>

                        <CollectionView x:Name="FiltersView"
                            ItemsSource="{Binding SelectedFilters}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="dto:FilterItem">
                                    <Grid ColumnDefinitions="*,*,Auto">

                                        <Label Text="{Binding Type}"/>

                                        <Label Grid.Column="1"
                                             Text="{Binding Name}"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>


                    </VerticalStackLayout>

                    

                </VerticalStackLayout>
            </ScrollView>

        </Border>

        <Button Grid.Row="1"
            Grid.Column="1"
        Text="Cancel"
        Command="{Binding CancelCommand}"
        Style="{StaticResource PopupCancelButtonStyle}"
        Margin="5,10"/>

        <Button Grid.Row="1"
            Grid.Column="0"
        Text="Create"
        Margin="5,10"
        Command="{Binding CreateCommand}"
        Style="{StaticResource PopupConfirmButtonStyle}"/>
    </Grid>

</toolkit:Popup>