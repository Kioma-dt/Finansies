<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:entity="clr-namespace:BuisnessLogic.UseCases.TransfersUseCasses.Commands;assembly=BuisnessLogic"
    x:TypeArguments="entity:CreateTransferCommand"
    xmlns:viewmodel="clr-namespace:UI.PopUps.ViewModels"
    x:Class="UI.Popups.TransferCreatePopUp"
    x:DataType="viewmodel:TransferCreatePopUpModel"
    
    BackgroundColor="#99000000"
    >

    <Grid RowDefinitions="*, Auto"
      ColumnDefinitions="*, *"
      RowSpacing="20"
      ColumnSpacing="10">

        <Border Grid.Row="0"
        Grid.ColumnSpan="2"
        WidthRequest="320"
        StrokeThickness="1"
        Style="{StaticResource PrimaryPopupBorderStyle}">

            <ScrollView
                VerticalScrollBarVisibility="Never"
                HorizontalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Create Transfer"
                            Style="{StaticResource PopupTitleLabelStyle}"/>

                    <VerticalStackLayout Spacing="5">

                        <Label 
                            Text="Enter Description"
                           Style="{StaticResource SectionLabelStyle}"/>

                        <Entry Placeholder="Transfer Description"
                            Text="{Binding Description}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">

                        <Label 
                            Text="Enter Amount"
                           Style="{StaticResource SectionLabelStyle}"/>


                        <Entry Placeholder="Transfer Amount"
                            Keyboard="Numeric"
                            Text="{Binding Amount}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">

                        <Label 
                                Text="Select Date"
                               Style="{StaticResource SectionLabelStyle}"/>


                        <DatePicker
                            Date="{Binding Date}"/>
                    </VerticalStackLayout>


                    <Picker Title="Select From Account"
                         ItemsSource="{Binding Accounts}"
                         SelectedItem="{Binding SelectedFromAccount}"
                         ItemDisplayBinding="{Binding Name}"/>

                    <Picker Title="Select To Account"
                         ItemsSource="{Binding Accounts}"
                         SelectedItem="{Binding SelectedToAccount}"
                         ItemDisplayBinding="{Binding Name}"/>


                </VerticalStackLayout>
            </ScrollView>

        </Border>

        <Button Grid.Row="1"
            Grid.Column="1"
        Text="Cancel"
        Command="{Binding CancelCommand}"
        Style="{StaticResource PopupCancelButtonStyle}"
        Margin="5,10"/>

        <Button Grid.Row="1"
            Grid.Column="0"
        Text="Create"
        Margin="5,10"
        Command="{Binding CreateCommand}"
        Style="{StaticResource PopupConfirmButtonStyle}"/>
    </Grid>
</toolkit:Popup>