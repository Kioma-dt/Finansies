<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:entity="clr-namespace:BuisnessLogic.UseCases.TransfersUseCasses.Commands;assembly=BuisnessLogic"
    x:TypeArguments="entity:CreateTransferCommand"
    xmlns:viewmodel="clr-namespace:UI.PopUps.ViewModels"
    x:Class="UI.Popups.TransferCreatePopUp"
    x:DataType="viewmodel:TransferCreatePopUpModel">

    <Border Padding="20"
            BackgroundColor="White"
            WidthRequest="320"
            Stroke="LightGray"
            StrokeThickness="1">

        <VerticalStackLayout Spacing="12">

            <Label Text="Create Transfer"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="Black"/>

            <Entry Placeholder="Transfer Description"
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   Text="{Binding Description}"/>

            <Entry Placeholder="Amount"
                   Keyboard="Numeric"
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   Text="{Binding Amount}"/>

            <DatePicker TextColor="Black"
                Date="{Binding Date}"/>

            <Picker Title="Select From Account"
                    TextColor="Black"
                    TitleColor="Gray"
                    ItemsSource="{Binding Accounts}"
                    SelectedItem="{Binding SelectedFromAccount}"
                    ItemDisplayBinding="{Binding Name}"/>

            <Picker Title="Select To Account"
                TextColor="Black"
                TitleColor="Gray"
                ItemsSource="{Binding Accounts}"
                SelectedItem="{Binding SelectedToAccount}"
                ItemDisplayBinding="{Binding Name}"/>

            <HorizontalStackLayout Spacing="10">

                <Button Text="Cancel"
                        BackgroundColor="#9E9E9E"
                        TextColor="White"
                        CornerRadius="8"
                        Command="{Binding CancelCommand}"/>

                <Button Text="Create"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="8"
                        Command="{Binding CreateCommand}"/>

            </HorizontalStackLayout>

        </VerticalStackLayout>

    </Border>

</toolkit:Popup>