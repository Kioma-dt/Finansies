<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:entity="clr-namespace:BuisnessLogic.UseCases.AccountsUseCases.Commands;assembly=BuisnessLogic"
    x:TypeArguments="entity:CreateAccountCommand"
    xmlns:viewmodel="clr-namespace:UI.PopUps.ViewModels"
    x:Class="UI.Popups.AccountCreatePopUp"
    x:DataType="viewmodel:AccountCreatePopUpModel">

    <Border Padding="20"
            BackgroundColor="White"
            WidthRequest="320"
            Stroke="LightGray"
            StrokeThickness="1">

        <VerticalStackLayout Spacing="12">

            <Label Text="Create Account"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="Black"/>

            <Entry x:Name="NameEntry"
                   Placeholder="Account name"
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   Text="{Binding Name}"/>

            <Entry x:Name="BalanceEntry"
                   Placeholder="Balance"
                   Keyboard="Numeric"
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   Text="{Binding Balance}"/>

            <Picker x:Name="ParentPicker"
                    Title="Select parent account"
                    TextColor="Black"
                    TitleColor="Gray"
                    ItemsSource="{Binding Parents}"
                    SelectedItem="{Binding SelectedParent}"
                    ItemDisplayBinding="{Binding Name}"/>

            <HorizontalStackLayout Spacing="10">

                <Button Text="Cancel"
                        BackgroundColor="#9E9E9E"
                        TextColor="White"
                        CornerRadius="8"
                        Command="{Binding CancelCommand}"/>

                <Button Text="Create"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="8"
                        Command="{Binding CreateCommand}"/>

            </HorizontalStackLayout>

        </VerticalStackLayout>

    </Border>

</toolkit:Popup>