<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:entity="clr-namespace:BuisnessLogic.UseCases.AccountsUseCases.Commands;assembly=BuisnessLogic"
    x:TypeArguments="entity:CreateAccountCommand"
    xmlns:viewmodel="clr-namespace:UI.PopUps.ViewModels"
    x:Class="UI.Popups.AccountCreatePopUp"
    x:DataType="viewmodel:AccountCreatePopUpModel"
    
    BackgroundColor="#99000000"
    >

    <Grid RowDefinitions="*, Auto"
          ColumnDefinitions="*, *"
          RowSpacing="20"
          ColumnSpacing="10">

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                WidthRequest="320"
                StrokeThickness="1"
                Style="{StaticResource PrimaryPopupBorderStyle}">

            <ScrollView
                VerticalScrollBarVisibility="Never"
                HorizontalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Create Account"
                        Style="{StaticResource PopupTitleLabelStyle}"/>

                    <VerticalStackLayout Spacing="5">

                        <Label 
                            Text="Enter Name"
                           Style="{StaticResource SectionLabelStyle}"/>

                        <Entry 
                            x:Name="NameEntry"
                            Placeholder="Account name"
                            Text="{Binding Name}"/>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">

                        <Label 
                            Text="Enter Start Balnce"
                           Style="{StaticResource SectionLabelStyle}"/>

                        <Entry 
                            x:Name="BalanceEntry"
                            Placeholder="Balance"
                            Keyboard="Numeric"
                            Text="{Binding Balance}"/>

                    </VerticalStackLayout>

                    <Picker x:Name="ParentPicker"
                         Title="Select Parent Account"
                         ItemsSource="{Binding Parents}"
                         SelectedItem="{Binding SelectedParent}"
                         ItemDisplayBinding="{Binding Name}"/>  

                </VerticalStackLayout>
            </ScrollView>

        </Border>

        <Button Grid.Row="1"
                Grid.Column="1"
            Text="Cancel"
            Command="{Binding CancelCommand}"
            Style="{StaticResource PopupCancelButtonStyle}"
            Margin="5,10"/>

        <Button Grid.Row="1"
                Grid.Column="0"
            Text="Create"
            Margin="5,10"
            Command="{Binding CreateCommand}"
            Style="{StaticResource PopupConfirmButtonStyle}"/>
    </Grid>

</toolkit:Popup>