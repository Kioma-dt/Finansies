<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:dto="clr-namespace:UI.Popups"
    x:TypeArguments="dto:DateRangeDTO"
    x:Class="UI.Popups.DateRangePopUp"
    xmlns:viewmodel="clr-namespace:UI.PopUps.ViewModels"
    x:DataType="viewmodel:DateRangePopUpModel"
    
    BackgroundColor="#99000000"
    >

    <Grid RowDefinitions="*, Auto"
       ColumnDefinitions="*, *"
       RowSpacing="20"
       ColumnSpacing="10">

        <Border Grid.Row="0"
             Grid.ColumnSpan="2"
             WidthRequest="320"
             StrokeThickness="1"
             Style="{StaticResource PrimaryPopupBorderStyle}">

            <ScrollView
             VerticalScrollBarVisibility="Never"
             HorizontalScrollBarVisibility="Never">

                <VerticalStackLayout
                    Spacing="20">

                    <VerticalStackLayout Spacing="5">

                        <Label 
                          Text="Select Start Date"
                         Style="{StaticResource SectionLabelStyle}"/>

                        <DatePicker 
                                x:Name="StartDatePicker"
                                Date="{Binding StartDate}"/>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">

                        <Label 
                              Text="Select End Date"
                             Style="{StaticResource SectionLabelStyle}"/>


                        <DatePicker
                                x:Name="EndDatePicker"
                                Date="{Binding EndDate}"/>

                    </VerticalStackLayout>

                </VerticalStackLayout>

            </ScrollView>

        </Border>

        <Button Grid.Row="1"
             Grid.Column="1"
         Text="Cancel"
         Command="{Binding CancelCommand}"
         Style="{StaticResource PopupCancelButtonStyle}"
         Margin="5,10"/>

        <Button Grid.Row="1"
             Grid.Column="0"
         Text="Select"
         Margin="5,10"
         Command="{Binding CreateCommand}"
         Style="{StaticResource PopupConfirmButtonStyle}"/>
    </Grid>

</toolkit:Popup>