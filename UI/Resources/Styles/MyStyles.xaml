<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <!-- ========================= -->
    <!-- COLORS                    -->
    <!-- ========================= -->

    <!-- Main -->
    <Color x:Key="PrimaryYellow">#FFD600</Color>
    <Color x:Key="PrimaryPurple">#C9A0FF</Color>

    <!-- Backgrounds -->
    <Color x:Key="BackgroundBlack">#0F0F0F</Color>
    <Color x:Key="SecondaryBlack">#1A1A1A</Color>
    <Color x:Key="CardBlack">#242424</Color>

    <!-- Text -->
    <Color x:Key="WhiteText">#FFFFFF</Color>
    <Color x:Key="MutedText">#B8B8B8</Color>

    <!-- Borders -->
    <Color x:Key="BorderGray">#3A3A3A</Color>

    <!-- States -->
    <Color x:Key="SuccessGreen">#4CAF50</Color>
    <Color x:Key="DangerRed">#FF5252</Color>

    <Color x:Key="MoneyPositive">#4CAF50</Color>
    <Color x:Key="MoneyNegative">#FF5252</Color>

    <!-- ========================= -->
    <!-- PAGE / LAYOUT             -->
    <!-- ========================= -->

    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor"
                Value="{StaticResource BackgroundBlack}" />
    </Style>

    <Style TargetType="ScrollView">
        <Setter Property="BackgroundColor"
                Value="{StaticResource BackgroundBlack}" />
    </Style>

    <Style x:Key="CardStyle"
           TargetType="Border">

        <Setter Property="BackgroundColor"
                Value="{StaticResource CardBlack}" />

        <Setter Property="Stroke"
                Value="{StaticResource BorderGray}" />

        <Setter Property="StrokeThickness"
                Value="1" />

        <Setter Property="Padding"
                Value="16" />

        <Setter Property="Margin"
                Value="6" />

        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="18"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================= -->
    <!-- LABELS                    -->
    <!-- ========================= -->

    <Style TargetType="Label">

        <Setter Property="TextColor"
                Value="{StaticResource WhiteText}" />

        <Setter Property="FontSize"
                Value="15" />
    </Style>

    <Style x:Key="TitleLabelStyle"
           TargetType="Label">

        <Setter Property="TextColor"
                Value="{StaticResource PrimaryYellow}" />

        <Setter Property="FontSize"
                Value="28" />

        <Setter Property="FontAttributes"
                Value="Bold" />
    </Style>

    <Style x:Key="SectionLabelStyle"
           TargetType="Label">

        <Setter Property="TextColor"
                Value="{StaticResource PrimaryPurple}" />

        <Setter Property="FontSize"
                Value="15" />
    </Style>

    <Style x:Key="MutedLabelStyle"
           TargetType="Label">

        <Setter Property="TextColor"
                Value="{StaticResource MutedText}" />

        <Setter Property="FontSize"
                Value="13" />
    </Style>

    <!-- ========================= -->
    <!-- BUTTONS                   -->
    <!-- ========================= -->

    <Style TargetType="Button">

        <Setter Property="CornerRadius"
            Value="14" />

        <Setter Property="Padding"
            Value="14,10" />

        <Setter Property="FontSize"
            Value="16" />

        <Setter Property="FontAttributes"
            Value="Bold" />

        <Setter Property="TextColor"
            Value="Black" />

        <Setter Property="BackgroundColor"
            Value="{StaticResource PrimaryYellow}" />

        <!-- PRESS ANIMATION -->
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>

                <VisualStateGroup Name="CommonStates">

                    <!-- NORMAL -->
                    <VisualState Name="Normal">
                        <VisualState.Setters>

                            <Setter Property="Scale"
                                Value="1" />

                            <Setter Property="Opacity"
                                Value="1" />

                        </VisualState.Setters>
                    </VisualState>

                    <!-- PRESSED -->
                    <VisualState Name="Pressed">
                        <VisualState.Setters>

                            <Setter Property="Scale"
                                Value="0.95" />

                            <Setter Property="Opacity"
                                Value="0.85" />

                        </VisualState.Setters>
                    </VisualState>

                    <!-- DISABLED -->
                    <VisualState Name="Disabled">
                        <VisualState.Setters>

                            <Setter Property="Opacity"
                                Value="0.45" />

                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>

            </VisualStateGroupList>
        </Setter>

    </Style>

    <Style x:Key="PurpleButtonStyle"
           TargetType="Button">

        <Setter Property="BackgroundColor"
                Value="#60187a" />

        <Setter Property="TextColor"
                Value="White" />
    </Style>

    <Style x:Key="DangerButtonStyle"
           TargetType="Button">

        <Setter Property="BackgroundColor"
                Value="{StaticResource DangerRed}" />

        <Setter Property="TextColor"
                Value="White" />
    </Style>

    <Style x:Key="SecondaryButtonStyle"
           TargetType="Button">

        <Setter Property="BackgroundColor"
                Value="{StaticResource SecondaryBlack}" />

        <Setter Property="BorderColor"
                Value="{StaticResource PrimaryPurple}" />

        <Setter Property="BorderWidth"
                Value="1" />

        <Setter Property="TextColor"
                Value="{StaticResource WhiteText}" />
    </Style>

    <!-- ========================= -->
    <!-- ENTRY                     -->
    <!-- ========================= -->

    <Style TargetType="Entry">

        <Setter Property="BackgroundColor"
                Value="{StaticResource SecondaryBlack}" />

        <Setter Property="TextColor"
                Value="{StaticResource WhiteText}" />

        <Setter Property="PlaceholderColor"
                Value="{StaticResource MutedText}" />

        <Setter Property="Margin"
                Value="0,4" />

        <Setter Property="HeightRequest"
                Value="48" />

        <Setter Property="VisualStateManager.VisualStateGroups">

            <VisualStateGroupList>

                <VisualStateGroup x:Name="CommonStates">

                    <!-- NORMAL -->
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>

                            <Setter Property="Opacity"
                                Value="1" />

                            <Setter Property="BackgroundColor"
                                Value="{StaticResource SecondaryBlack}" />

                            <Setter Property="TextColor"
                                Value="{StaticResource WhiteText}" />

                        </VisualState.Setters>
                    </VisualState>

                    <!-- DISABLED -->
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>

                            <Setter Property="BackgroundColor"
                                Value="#1A1A1A" />

                            <Setter Property="TextColor"
                                Value="#777777" />

                            <Setter Property="PlaceholderColor"
                                Value="#555555" />

                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>

            </VisualStateGroupList>

        </Setter>
    </Style>

    <!-- ========================= -->
    <!-- PICKER                    -->
    <!-- ========================= -->

    <Style TargetType="Picker">

        <Setter Property="BackgroundColor"
                Value="{StaticResource SecondaryBlack}" />

        <Setter Property="TextColor"
                Value="{StaticResource WhiteText}" />

        <Setter Property="TitleColor"
                Value="{StaticResource PrimaryPurple}" />


        <Setter Property="VisualStateManager.VisualStateGroups">

            <VisualStateGroupList>

                <VisualStateGroup x:Name="CommonStates">

                    <!-- NORMAL -->
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Opacity"
                                Value="1" />
                        </VisualState.Setters>
                    </VisualState>

                    <!-- DISABLED -->
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>

                            <Setter Property="TextColor"
                                Value="#777777" />

                            <Setter Property="BackgroundColor"
                                Value="#1A1A1A" />

                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>

            </VisualStateGroupList>

        </Setter>
    </Style>

    <!-- ========================= -->
    <!-- DATE PICKER               -->
    <!-- ========================= -->

    <Style TargetType="DatePicker">

        <Setter Property="BackgroundColor"
                Value="{StaticResource SecondaryBlack}" />

        <Setter Property="TextColor"
                Value="{StaticResource WhiteText}" />
    </Style>

    <!-- ========================= -->
    <!-- CHECKBOX                  -->
    <!-- ========================= -->

    <Style TargetType="CheckBox">

        <Setter Property="Color"
                Value="{StaticResource PrimaryYellow}" />
    </Style>

    <!-- ========================= -->
    <!-- COLLECTION VIEW HEADERS   -->
    <!-- ========================= -->

    <Style x:Key="TableHeaderLabelStyle"
           TargetType="Label">

        <Setter Property="TextColor"
                Value="{StaticResource PrimaryYellow}" />

        <Setter Property="FontAttributes"
                Value="Bold" />

        <Setter Property="FontSize"
                Value="15" />
    </Style>

    <!-- ========================= -->
    <!-- CHART CONTAINERS          -->
    <!-- ========================= -->

    <Style x:Key="ChartContainerStyle"
           TargetType="Border">

        <Setter Property="BackgroundColor"
                Value="{StaticResource CardBlack}" />

        <Setter Property="Padding"
                Value="14" />

        <Setter Property="Margin"
                Value="8" />

        <Setter Property="Stroke"
                Value="{StaticResource PrimaryPurple}" />

        <Setter Property="StrokeThickness"
                Value="1" />

        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="20"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LogoutButtonStyle"
       TargetType="Button">
        <!-- Фон -->
        <Setter Property="BackgroundColor"
            Value="#1E1E1E"/>

        <!-- Обводка -->
        <Setter Property="BorderColor"
            Value="#FFB74D"/>

        <Setter Property="BorderWidth"
            Value="2"/>

        <!-- Текст -->
        <Setter Property="TextColor"
            Value="#FFCC80"/>

        <!-- Размеры -->
        <Setter Property="CornerRadius"
            Value="14"/>

        <Setter Property="Padding"
            Value="14,10"/>

        <Setter Property="FontSize"
            Value="16"/>

        <Setter Property="FontAttributes"
            Value="Bold"/>

        <!-- Тень -->
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow
                Brush="#66000000"
                Offset="0,4"
                Radius="12"
                Opacity="0.75"/>
            </Setter.Value>
        </Setter>

        <!-- States -->
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>

                <VisualStateGroup Name="CommonStates">

                    <!-- NORMAL -->
                    <VisualState Name="Normal">
                        <VisualState.Setters>

                            <Setter Property="Scale"
                                Value="1"/>

                        </VisualState.Setters>
                    </VisualState>

                    <!-- PRESSED -->
                    <VisualState Name="Pressed">
                        <VisualState.Setters>

                            <Setter Property="Scale"
                                Value="0.96"/>


                        </VisualState.Setters>
                    </VisualState>

                    <!-- DISABLED -->
                    <VisualState Name="Disabled">
                        <VisualState.Setters>

                            <Setter Property="Opacity"
                                Value="0.45"/>

                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>

            </VisualStateGroupList>
        </Setter>

    </Style>

    <Style TargetType="toolkit:Popup">

        <!-- Затемнение фона -->
        <Setter Property="BackgroundColor"
            Value="#99000000"/>

        <!-- Закрытие по тапу вне popup -->
        <Setter Property="CanBeDismissedByTappingOutsideOfPopup"
                Value="False"/>

    </Style>

    <!-- ========================= -->
    <!-- POPUP CONTAINER STYLE -->
    <!-- ========================= -->

    <Style x:Key="PrimaryPopupBorderStyle"
       TargetType="Border">

        <Setter Property="BackgroundColor"
            Value="#121212"/>

        <Setter Property="Stroke"
            Value="#C9A0FF"/>

        <Setter Property="StrokeThickness"
            Value="2"/>

        <Setter Property="Padding"
            Value="24"/>

        <Setter Property="Shadow">

            <Setter.Value>
                <Shadow
                Brush="#80000000"
                Offset="0,8"
                Radius="18"
                Opacity="0.75"/>
            </Setter.Value>

        </Setter>

        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="24"/>
            </Setter.Value>
        </Setter>

    </Style>



    <!-- ========================= -->
    <!-- POPUP TITLE -->
    <!-- ========================= -->

    <Style x:Key="PopupTitleLabelStyle"
       TargetType="Label">

        <Setter Property="TextColor"
            Value="{StaticResource PrimaryYellow}"/>

        <Setter Property="FontSize"
            Value="24"/>

        <Setter Property="FontAttributes"
            Value="Bold"/>

        <Setter Property="HorizontalTextAlignment"
            Value="Center"/>

    </Style>



    <!-- ========================= -->
    <!-- POPUP MESSAGE -->
    <!-- ========================= -->

    <Style x:Key="PopupMessageLabelStyle"
       TargetType="Label">

        <Setter Property="TextColor"
            Value="White"/>

        <Setter Property="FontSize"
            Value="15"/>

        <Setter Property="LineBreakMode"
            Value="WordWrap"/>

    </Style>



    <!-- ========================= -->
    <!-- CONFIRM BUTTON -->
    <!-- ========================= -->

    <Style x:Key="PopupConfirmButtonStyle"
       TargetType="Button">

        <Setter Property="BackgroundColor"
            Value="{StaticResource PrimaryYellow}" />

        <Setter Property="TextColor"
            Value="Black" />

        <Setter Property="CornerRadius"
            Value="14" />

        <Setter Property="Padding"
            Value="14,10" />

        <Setter Property="FontSize"
            Value="16" />

        <Setter Property="FontAttributes"
            Value="Bold" />

        <Setter Property="BorderColor"
            Value="{StaticResource PrimaryYellow}" />

        <Setter Property="BorderWidth"
            Value="2" />

        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>

                <VisualStateGroup Name="CommonStates">

                    <VisualState Name="Normal"/>

                    <VisualState Name="Pressed">
                        <VisualState.Setters>

                            <Setter Property="Scale"
                                Value="0.96"/>

                            <Setter Property="Opacity"
                                Value="0.85"/>

                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>

            </VisualStateGroupList>
        </Setter>

    </Style>



    <!-- ========================= -->
    <!-- CANCEL BUTTON -->
    <!-- ========================= -->

    <Style x:Key="PopupCancelButtonStyle"
       TargetType="Button">

        <!-- Фон -->
        <Setter Property="BackgroundColor"
    Value="#1E1E1E"/>

        <!-- Обводка -->
        <Setter Property="BorderColor"
    Value="#FFB74D"/>

        <Setter Property="BorderWidth"
    Value="2"/>

        <!-- Текст -->
        <Setter Property="TextColor"
    Value="#FFCC80"/>

        <!-- Размеры -->
        <Setter Property="CornerRadius"
    Value="14"/>

        <Setter Property="Padding"
    Value="14,10"/>

        <Setter Property="FontSize"
    Value="16"/>

        <Setter Property="FontAttributes"
    Value="Bold"/>

        <!-- Тень -->
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow
        Brush="#66000000"
        Offset="0,4"
        Radius="12"
        Opacity="0.75"/>
            </Setter.Value>
        </Setter>

        <!-- States -->
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>

                <VisualStateGroup Name="CommonStates">

                    <!-- NORMAL -->
                    <VisualState Name="Normal">
                        <VisualState.Setters>

                            <Setter Property="Scale"
                        Value="1"/>

                        </VisualState.Setters>
                    </VisualState>

                    <!-- PRESSED -->
                    <VisualState Name="Pressed">
                        <VisualState.Setters>

                            <Setter Property="Scale"
                        Value="0.96"/>


                        </VisualState.Setters>
                    </VisualState>

                    <!-- DISABLED -->
                    <VisualState Name="Disabled">
                        <VisualState.Setters>

                            <Setter Property="Opacity"
                        Value="0.45"/>

                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>

            </VisualStateGroupList>
        </Setter>

    </Style>

    <Style x:Key="PrimaryProgressBarStyle"
       TargetType="ProgressBar">

        <!-- Высота -->
        <Setter Property="HeightRequest"
            Value="10"/>

        <!-- Цвет заполнения -->
        <Setter Property="ProgressColor"
            Value="{StaticResource PrimaryYellow}"/>

        <!-- Фон полосы -->
        <Setter Property="BackgroundColor"
            Value="#60187a"/>

        <!-- Отступы -->
        <Setter Property="Margin"
            Value="0,6"/>

        <!-- Прозрачность -->
        <Setter Property="Opacity"
            Value="0.95"/>

        <!-- Скругление через ScaleY -->
        <Setter Property="ScaleY"
            Value="1.4"/>

    </Style>


</ResourceDictionary>