<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:UI.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:entity="clr-namespace:UI.ViewModels"
             xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.TransferView"
             x:DataType="viewmodel:TransfersViewModel">


    <Grid RowDefinitions="*, Auto">


        <CollectionView Grid.Column="0"
                        Grid.Row="0"
                        ItemsSource="{Binding DisplayedTransfers}">

            <CollectionView.Header>
                <Grid ColumnDefinitions="*,*,*,*,*"
                      Padding="10"
                      BackgroundColor="#2d2d2d">


                    <Label Text="Description" Grid.Column="0" TextColor="White"/>
                    <Label Text="Amount" Grid.Column="1" TextColor="White"/>
                    <Label Text="Date" Grid.Column="2" TextColor="White"/>
                    <Label Text="FromAccount" Grid.Column="3" TextColor="White"/>
                    <Label Text="ToAccount" Grid.Column="4" TextColor="White"/>

                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="entity:DisplayedTransfer">
                    <Grid ColumnDefinitions="*,*,*,*,*"
                          Padding="10">


                        <Label Text="{Binding Desciption}" Grid.Column="0"/>
                        <Label Text="{Binding Amount}" Grid.Column="1"/>
                        <Label Text="{Binding Date}"  Grid.Column="2" />
                        <Label Text="{Binding FromAccountName}" Grid.Column="3"/>
                        <Label Text="{Binding ToAccountName}" Grid.Column="4"/>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Grid.Row="1"
                Text="Transfer Money"
                Command="{Binding TransferMoneyCommand}" 
            BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="45"/>


    </Grid>
</ContentView>