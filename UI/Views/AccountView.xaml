<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:entity="clr-namespace:BuisnessLogic.Entities;assembly=BuisnessLogic"
             xmlns:viewmodel="clr-namespace:UI.ViewModels"
             xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.AccountView"
             x:DataType="viewmodel:AccountViewModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <converter:IndentConverter x:Key="indentConverter"/>
            <converter:MoneyColorConverter
                        x:Key="moneyColorConverter"
                        PositiveColor="{StaticResource MoneyPositive}"
                        NegativeColor="{StaticResource MoneyNegative}" />
        </ResourceDictionary>
    </ContentView.Resources>

    <Grid RowDefinitions="*, Auto"
          Padding="10"
          RowSpacing="10">

        <CollectionView Grid.Row="0"
                         ItemsSource="{Binding DisplayedAccounts}">

            <CollectionView.Header>
                <Grid ColumnDefinitions="*,*"
                      Padding="10"
                      BackgroundColor="#2d2d2d">

                    <Label Grid.Column="0" 
                        Text="Account"
                        Style="{StaticResource TableHeaderLabelStyle}"/>

                    <Label Grid.Column="1" 
                            Text="Balance"
                           HorizontalOptions="End"
                            Style="{StaticResource TableHeaderLabelStyle}"/>

                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodel:DisplayedAccount">

                    <Grid ColumnDefinitions="*, Auto">

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:AccountViewModel}}, Path=ChangeSelectedAccountCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <FlyoutBase.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem 
                                    Text="UnSelect Account"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:AccountViewModel}}, Path=UnSelectAccountCommand}"
                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:AccountViewModel}}, Path=IsSelectedAccount}"/>
                            </MenuFlyout>
                        </FlyoutBase.ContextFlyout>

                        <Grid Padding="{Binding Level, Converter={StaticResource indentConverter}}">

                            <Label Text="{Binding Name}"/>

                        </Grid>

                        <Label Grid.Column="1"
                               Padding="10, 10, 10, 10"
                               Text="{Binding Balance}"
                               TextColor="{Binding Balance, Converter={StaticResource moneyColorConverter}}"
                               HorizontalOptions="End"/>
                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Grid.Row="1"
                Text="Add Account"
                Command="{Binding AddAccountCommand}"
                Style="{StaticResource PurpleButtonStyle}"/>

    </Grid>

</ContentView>