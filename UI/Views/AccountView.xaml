<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:entity="clr-namespace:BuisnessLogic.Entities;assembly=BuisnessLogic"
             xmlns:viewmodel="clr-namespace:UI.ViewModels"
             xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.AccountView"
             x:DataType="viewmodel:AccountViewModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <converter:IndentConverter x:Key="indentConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>

    <Grid RowDefinitions="*, Auto"
          Padding="10"
          RowSpacing="10">

        <CollectionView Grid.Row="0"
                         ItemsSource="{Binding FlatAccounts}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodel:AccountNode">

                    <Grid ColumnDefinitions="*, Auto">

                        <Grid Padding="{Binding Level, Converter={StaticResource indentConverter}}">

                            <Label Text="{Binding Account.Name}"
                                   TextColor="White" />

                        </Grid>

                        <Label Grid.Column="1"
                               Text="{Binding Account.TotalBalance}"
                               TextColor="LightGreen"
                               HorizontalOptions="End"/>
                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Grid.Row="1"
                Text="Add Account"
                Command="{Binding AddAccountCommand}"
                BackgroundColor="#4CAF50"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="45"/>

    </Grid>

</ContentView>