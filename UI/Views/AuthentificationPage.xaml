<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:UI.ViewModels"
    xmlns:converter="clr-namespace:UI.Converters"
    x:Class="UI.Views.AuthentificationPage"
    x:DataType="viewmodel:AuthentificationPageViewModel">

    <Border
        Margin="500, 30">
        <Grid RowDefinitions="*, *, *, *, *"
            ColumnDefinitions="Auto, *"
            Padding="30"
            RowSpacing="15"
            ColumnSpacing="10"
            VerticalOptions="Center">

            <Label
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Text="Your Personal Finansies"
                Style="{StaticResource Headline}"
                HorizontalOptions="Center"/>

            <Label Grid.Row="1"
                   Grid.Column="0"
                   Text="User Name: "
                   VerticalOptions="Center"
                   Style="{StaticResource SectionLabelStyle}"/>

            <Entry Grid.Column="1"
                Grid.Row="1"
                Placeholder="User Name"
                Text="{Binding Name}" />

            <Label Grid.Row="2"
               Grid.Column="0"
               Text="Password: "
               VerticalOptions="Center"
               Style="{StaticResource SectionLabelStyle}"/>
            <Entry
                Grid.Row="2"
                Grid.Column="1"
                Placeholder="Password"
                IsPassword="True"
                Text="{Binding Password}" />

            <Grid ColumnDefinitions="*, *"
                Grid.Row="3" 
                Grid.ColumnSpan="2"
                ColumnSpacing="10">
                <Button
                    Grid.Column="0"
                    Text="Log In"
                    Command="{Binding LoginCommand}" />

                <Button
                    Grid.Column="1"
                    Grid.Row="4"
                    Text="Register"
                    Command="{Binding RegisterCommand}" />
            </Grid>

            

        </Grid>
    </Border>

</ContentPage>