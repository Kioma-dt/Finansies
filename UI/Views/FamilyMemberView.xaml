<?xml version="1.0" encoding="utf-8" ?>
<ContentView 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:entity="clr-namespace:UI.ViewModels"
    xmlns:viewmodel="clr-namespace:UI.ViewModels"
    xmlns:converter="clr-namespace:UI.Converters"
    x:Class="UI.Views.FamilyMemberView"
    x:DataType="viewmodel:FamilyMemberViewModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <converter:MoneyColorConverter
                x:Key="moneyColorConverter"
                PositiveColor="{StaticResource MoneyPositive}"
                NegativeColor="{StaticResource MoneyNegative}" />
        </ResourceDictionary>
    </ContentView.Resources>

    <Grid RowDefinitions="*,Auto"
          Padding="10">
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding DisplayedFamilyMembers}">

            <CollectionView.Header>
                <Grid ColumnDefinitions="*,*,*"
                    Padding="10"
                    BackgroundColor="#2d2d2d">

                    <Label Text="Name"
                         Grid.Column="0"
                         Style="{StaticResource TableHeaderLabelStyle}"/>

                    <Label Text="Transactions Count"
                         Grid.Column="1"
                         Style="{StaticResource TableHeaderLabelStyle}"/>   

                    <Label Text="Total Amount"
                         Grid.Column="2"
                         Style="{StaticResource TableHeaderLabelStyle}"/>
                </Grid>


            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodel:DisplayedFamilyMember">

                    <Grid ColumnDefinitions="*,*,*"
                          Padding="10">

                        <Label Text="{Binding Name}"/>

                        <Label Text="{Binding TransactionsCount}"
                               Grid.Column="1"/>

                        <Label Text="{Binding TotalAmount}"
                               Grid.Column="2"
                               TextColor="{Binding TotalAmount, Converter={StaticResource moneyColorConverter}}"/>

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>


        <Button Grid.Row="1"
                Text="Add Family Member"
                Command="{Binding AddFamilyMemberCommand}" 
                Style="{StaticResource PurpleButtonStyle}"
                 HorizontalOptions="End"
                 WidthRequest="220"/>

    </Grid>
</ContentView>