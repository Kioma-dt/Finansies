<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:UI.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:entity="clr-namespace:UI.ViewModels"
             xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.TransactionView"
             x:DataType="viewmodel:TransactionsViewModel">

    <Grid ColumnDefinitions="*">


        <CollectionView Grid.Column="0"
                        Grid.Row="0"
                        ItemsSource="{Binding DisplayedTransactions}">

            <CollectionView.Header>
                <Grid ColumnDefinitions="*,*,*,*,*,*,*,*"
                      Padding="10"
                      BackgroundColor="#2d2d2d">

                    <Label Text="Description" Grid.Column="0" TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionsViewModel}}, Path=ChangeSortingCommand}"
                                CommandParameter="Description" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Text="Amount" Grid.Column="1" TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionsViewModel}}, Path=ChangeSortingCommand}"
                                CommandParameter="Amount" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Text="Type" Grid.Column="2" TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionsViewModel}}, Path=ChangeSortingCommand}"
                                CommandParameter="Type" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Text="Date" Grid.Column="3" TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionsViewModel}}, Path=ChangeSortingCommand}"
                                CommandParameter="Date" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Text="Account" Grid.Column="4" TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionsViewModel}}, Path=ChangeSortingCommand}"
                                CommandParameter="AccountName" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Text="Category" Grid.Column="5" TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionsViewModel}}, Path=ChangeSortingCommand}"
                                CommandParameter="CategoryName" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="FamilyMember" Grid.Column="6" TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionsViewModel}}, Path=ChangeSortingCommand}"
                                CommandParameter="FamilyMemberName" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Text="Debt" Grid.Column="7" TextColor="White">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionsViewModel}}, Path=ChangeSortingCommand}"
                                CommandParameter="DebtName" />
                        </Label.GestureRecognizers>
                    </Label>

                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="entity:DisplayedTransaction">
                    <Grid ColumnDefinitions="*,*,*,*,*,*,*,*"
                          Padding="10">

                        <FlyoutBase.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem 
                                    Text="Update"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionsViewModel}}, Path=UpdateTransactionCommand}"
                                    CommandParameter="{Binding .}"/>
                            </MenuFlyout>
                        </FlyoutBase.ContextFlyout>

                        <Label Text="{Binding Description}" Grid.Column="0"/>
                        <Label Text="{Binding Amount}"  Grid.Column="1" />
                        <Label Text="{Binding Type}" Grid.Column="2"/>
                        <Label Text="{Binding Date}" Grid.Column="3"/>
                        

                        <Label Text="{Binding AccountName}" Grid.Column="4"/>
                        <Label Text="{Binding CategoryName, TargetNullValue='-'}" Grid.Column="5"/>
                        <Label Text="{Binding FamilyMemberName, TargetNullValue='-'}" Grid.Column="6"/>
                        <Label Text="{Binding DebtName, TargetNullValue='-'}" Grid.Column="7"/>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentView>