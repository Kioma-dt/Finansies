<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:UI.ViewModels"
             xmlns:entity="clr-namespace:BuisnessLogic.Entities;assembly=BuisnessLogic"
             xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.CategoryView"
             x:DataType="viewmodel:CategoryViewModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <converter:IndentConverter x:Key="indentConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>

    <Grid RowDefinitions="*, Auto"
          Padding="10"
          RowSpacing="10">

        <Grid Grid.Row="0" 
            RowDefinitions="Auto,*">

            <Grid ColumnDefinitions="2*, 3*, Auto, Auto"
              Padding="10"
              BackgroundColor="#2d2d2d">

                <Label Text="Name"
               TextColor="White"
               FontAttributes="Bold"/>

                <Label Grid.Column="1"
               Text="Description"
               TextColor="White"
               FontAttributes="Bold"/>

                <Label Grid.Column="2"
               Text="Count"
               TextColor="White"
               FontAttributes="Bold"/>

                <Label Grid.Column="3"
               Text="Total"
               TextColor="White"
               FontAttributes="Bold"/>
            </Grid>


            <CollectionView Grid.Row="1"
                    ItemsSource="{Binding FlatCategories}">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodel:CategoryNode">

                        <Grid ColumnDefinitions="2*, 3*, Auto, Auto">


                            <Label Grid.Column="0" 
                                Text="{Binding Category.Name}"
                               TextColor="White"
                                Padding="{Binding Level, Converter={StaticResource indentConverter}}"/> 


                            <Label Grid.Column="1"
                               Text="{Binding Category.Description}"
                               TextColor="Gray"
                               LineBreakMode="TailTruncation"/>


                            <Label Grid.Column="2"
                               Text="{Binding Category.Transactions.Count}"
                               TextColor="LightBlue"
                               HorizontalTextAlignment="End"/>


                            <Label Grid.Column="3"
                               Text="{Binding Category.TransactionsSum}"
                               TextColor="LightGreen"
                               HorizontalTextAlignment="End"/>

                        </Grid>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>

        <Button Grid.Row="1"
                Text="Add Category"
                Command="{Binding AddCategoryCommand}" 
            BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="45"/>

    </Grid>

</ContentView>