<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:UI.ViewModels"
             xmlns:entity="clr-namespace:UI.ViewModels"
             xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.CategoryView"
             x:DataType="viewmodel:CategoryViewModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <converter:IndentConverter x:Key="indentConverter"/>
            <converter:MoneyColorConverter
                    x:Key="moneyColorConverter"
                    PositiveColor="{StaticResource MoneyPositive}"
                    NegativeColor="{StaticResource MoneyNegative}" />
        </ResourceDictionary>
    </ContentView.Resources>

    <Grid RowDefinitions="*, Auto"
          Padding="10"
          RowSpacing="10">


        <CollectionView Grid.Row="0"
                    ItemsSource="{Binding DispalyedCategories}">

            <CollectionView.Header>

                <Grid ColumnDefinitions="*, *, *, *"
                  Padding="10"
                  BackgroundColor="#2d2d2d">

                    <Label Text="Name" 
                           Style="{StaticResource TableHeaderLabelStyle}"/>

                    <Label Grid.Column="1"
                       Text="Description"
                       Style="{StaticResource TableHeaderLabelStyle}"/>

                    <Label Grid.Column="2"
                       Text="Transactions Count"
                       Style="{StaticResource TableHeaderLabelStyle}"/>

                    <Label Grid.Column="3"
                       Text="Total Amount"
                       Style="{StaticResource TableHeaderLabelStyle}"/>
                </Grid>
            </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodel:DispalyedCategory">

                        <Grid ColumnDefinitions="*, *, *, *">


                            <Label Grid.Column="0" 
                                Text="{Binding Name}"
                                Padding="{Binding Level, Converter={StaticResource indentConverter}}"/> 


                            <Label Grid.Column="1"
                               Text="{Binding Description}"
                               Padding="10, 10, 0, 10"/>


                            <Label Grid.Column="2"
                               Text="{Binding NumberOfTransactions}"
                               Padding="10, 10, 0, 10"/>


                        <Label Grid.Column="3"
                               Text="{Binding Amount}"
                               TextColor="{Binding Amount, Converter={StaticResource moneyColorConverter}}"
                               Padding="10, 10, 0, 10"/>

                    </Grid>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        <Button Grid.Row="1"
                Text="Add Category"
                Command="{Binding AddCategoryCommand}" 
                 Style="{StaticResource PurpleButtonStyle}"
                HorizontalOptions="End"
                 WidthRequest="220"/>


    </Grid>

</ContentView>