<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:UI.ViewModels"
             xmlns:entity="clr-namespace:BuisnessLogic.Entities;assembly=BuisnessLogic"
             xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.CategoryView"
             x:DataType="viewmodel:CategoryViewModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <converter:IndentConverter x:Key="indentConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>

    <Grid RowDefinitions="*, Auto"
          Padding="10"
          RowSpacing="10">

        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding FlatCategories}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodel:CategoryNode">

                    <Grid ColumnDefinitions="*">

                        <Grid Padding="{Binding Level, Converter={StaticResource indentConverter}}">

                            <Label Text="{Binding Category.Name}"
                                   TextColor="White"/>

                        </Grid>

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Grid.Row="1"
                Text="Add Category"
                Command="{Binding LoadCommand}" 
            BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="45"/>

    </Grid>

</ContentView>