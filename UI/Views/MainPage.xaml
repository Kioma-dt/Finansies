<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:entity="clr-namespace:BuisnessLogic.Entities;assembly=BuisnessLogic"
            xmlns:viewmodel="clr-namespace:UI.ViewModels"
            xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.MainPage"
             x:DataType="viewmodel:MainPageViewModel"
             Title="MainPage">
    <Grid RowDefinitions="Auto,*"
      ColumnDefinitions="*,*">

        <HorizontalStackLayout Grid.Row="0"
                           Grid.ColumnSpan="2"
                           BackgroundColor="#1e1e1e"
                           Padding="10"
                           Spacing="10">
            <Button Text="Log Out"
                    Command="{Binding LogOutCommand}"/>

            <Button Text="Transactions"
                Command="{Binding ShowTransactionsCommand}" />

            <Button Text="Transfers"
                Command="{Binding ShowTransfersCommand}" />

            <Button Text="Categories"
                Command="{Binding ShowCategoriesCommand}" />

            <Button Text="FamilyMembers"
                Command="{Binding ShowFamilyMembersCommand}" />

            <Button Text="Plan Transactions"
                Command="{Binding ShowPlannedTransactionsCommand}" />

            <Button Text="Budgets"
                Command="{Binding ShowBudgetsCommand}" />
            
            <Button Text="Debts"
                Command="{Binding ShowDebtsCommand}" />

            <Button Text="Create Transactiom"
                Command="{Binding CreateTransactionCommand}" />

            <ContentView Content="{Binding DateRangeSelectorView}"/>

        </HorizontalStackLayout>

        <ContentView Grid.Row="1"
                     Grid.ColumnSpan="2"
                     Content="{Binding CentralView}"/>

        <ContentView Grid.Row="1"
                 Grid.Column="0"
                 Content="{Binding LeftView}" />

        <ContentView Grid.Row="1"
                 Grid.Column="1"
                 Content="{Binding RightView}" />

    </Grid>
</ContentPage>