<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:entity="clr-namespace:BuisnessLogic.Entities;assembly=BuisnessLogic"
            xmlns:viewmodel="clr-namespace:UI.ViewModels"
            xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.MainPage"
             x:DataType="viewmodel:MainPageViewModel"
             Title="MainPage">
    <Grid RowDefinitions="Auto,*"
      ColumnDefinitions="*,*">

        <HorizontalStackLayout Grid.Row="0"
                           Grid.ColumnSpan="2"
                           BackgroundColor="#1e1e1e"
                           Padding="10"
                           Spacing="10">

            <Button Text="Transactions"
                Command="{Binding ShowTransactionsCommand}" />

            <Button Text="Categories"
                Command="{Binding ShowCategoriesCommand}" />

        </HorizontalStackLayout>
        
        <ContentView Grid.Row="1"
                 Grid.Column="0"
                 Content="{Binding LeftView}" />

        <ContentView Grid.Row="1"
                 Grid.Column="1"
                 Content="{Binding RightView}" />

    </Grid>
</ContentPage>