<ContentView 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:UI.ViewModels"
    xmlns:entity="clr-namespace:BuisnessLogic.Entities;assembly=BuisnessLogic"
    xmlns:converter="clr-namespace:UI.Converters"
    x:Class="UI.Views.DateRangeSelectorView"
    x:DataType="viewmodel:DateRangeSelectorViewModel">

    <Grid ColumnDefinitions="Auto,*,Auto"
          RowDefinitions="*, Auto"
          Padding="5">

        <Button Grid.Column="0"
                Grid.RowSpan="2"
                Text="◀"
                Command="{Binding PrevCommand}"
                IsEnabled="{Binding CanNavigate}"/>

        <Border Grid.Column="1"
                Grid.Row="0"
                Padding="8"
                BackgroundColor="#2d2d2d"
                Stroke="Gray">

            <Label Text="{Binding RangeText}"
                   TextColor="White"
                   HorizontalOptions="Center">

                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ChangeModeCommand}"/>
                </Label.GestureRecognizers>

            </Label>

        </Border>

        <Label Grid.Column="1"
                Grid.Row="1"
               Text="{Binding Mode}"/>

        <Button Grid.Column="2"
                Grid.RowSpan="2"
                Text="▶"
                Command="{Binding NextCommand}"
                IsEnabled="{Binding CanNavigate}"/>

    </Grid>
</ContentView>