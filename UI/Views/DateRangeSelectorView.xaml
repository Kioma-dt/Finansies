<ContentView 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:UI.ViewModels"
    xmlns:entity="clr-namespace:BuisnessLogic.Entities;assembly=BuisnessLogic"
    xmlns:converter="clr-namespace:UI.Converters"
    x:Class="UI.Views.DateRangeSelectorView"
    x:DataType="viewmodel:DateRangeSelectorViewModel">

    <Grid ColumnDefinitions="Auto,*,Auto"
          ColumnSpacing="10"
          RowSpacing="10"
          RowDefinitions="*, Auto">

        <Button Grid.Column="0"
                Grid.RowSpan="2"
                Text="◀"
                Command="{Binding PrevCommand}"
                IsEnabled="{Binding CanNavigate}"/>

        <Border Grid.Column="1"
                Grid.Row="0"
                BackgroundColor="#2d2d2d"
                Stroke="Gray"
                Margin="0,4,0,0"
                Padding="7">

            <Label Text="{Binding RangeText}"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Style="{StaticResource SectionLabelStyle}">

                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ChangeModeCommand}"/>
                </Label.GestureRecognizers>

            </Label>

        </Border>


        <Button Grid.Column="2"
                Grid.RowSpan="2"
                Text="▶"
                Command="{Binding NextCommand}"
                IsEnabled="{Binding CanNavigate}"/>

    </Grid>
</ContentView>