<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:UI.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:entity="clr-namespace:BuisnessLogic.Entities;assembly=BuisnessLogic"
             xmlns:converter="clr-namespace:UI.Converters"
             x:Class="UI.Views.PlannedTransactionView"
             x:DataType="viewmodel:PlannedTransactionsViewModel">

    <ContentView.Resources>
        <ResourceDictionary>
            <converter:NotConfirmedConverter x:Key="notConfirmedConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>


    <Grid RowDefinitions="*, Auto">


        <CollectionView Grid.Column="0"
                        Grid.Row="0"
                        ItemsSource="{Binding PlannedTransactions}">

            <CollectionView.Header>
                <Grid ColumnDefinitions="*,*,*,*,*,*,*,*"
                      Padding="10"
                      BackgroundColor="#2d2d2d">


                    <Label Text="Description" Grid.Column="0" TextColor="White"/>
                    <Label Text="Status" Grid.Column="1" TextColor="White"/>
                    <Label Text="Amount" Grid.Column="2" TextColor="White"/>
                    <Label Text="Type" Grid.Column="3" TextColor="White"/>
                    <Label Text="Date" Grid.Column="4" TextColor="White"/>
                    <Label Text="Account" Grid.Column="5" TextColor="White"/>
                    <Label Text="Category" Grid.Column="6" TextColor="White"/>
                    <Label Text="FamilyMember" Grid.Column="7" TextColor="White"/>

                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="entity:PlannedTransaction">
                    <Grid ColumnDefinitions="*,*,*,*,*,*,*,*"
                          Padding="10">

                        <FlyoutBase.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem 
                                Text="Confirm"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:PlannedTransactionsViewModel}}, Path=ConfirmTransactionCommand}"
                                CommandParameter="{Binding .}"
                                IsEnabled="{Binding Status, Converter={StaticResource notConfirmedConverter}}"/>   
                            </MenuFlyout>
                        </FlyoutBase.ContextFlyout>

                        <Label Text="{Binding Description}" Grid.Column="0"/>
                        <Label Text="{Binding Status}" Grid.Column="1"/>
                        <Label Text="{Binding Amount}"  Grid.Column="2" />
                        <Label Text="{Binding Type}" Grid.Column="3"/>
                        <Label Text="{Binding PlannedDate, StringFormat='{0:dd.MM.yyyy}'}" Grid.Column="4"/>
                        <Label Text="{Binding Account.Name, TargetNullValue='-'}" Grid.Column="5"/>
                        <Label Text="{Binding Category.Name, TargetNullValue='-'}" Grid.Column="6"/>
                        <Label Text="{Binding FamilyMember.Name, TargetNullValue='-'}" Grid.Column="7"/>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Grid.Row="1"
                Text="Plan Transaction"
                Command="{Binding PlanTransactionCommand}" 
            BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="45"/>


    </Grid>
</ContentView>